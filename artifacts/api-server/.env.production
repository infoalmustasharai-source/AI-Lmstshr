# Production Environment Variables for Backend

# General
NODE_ENV=production
PORT=3000

# Database (using SQLite in production)
DATABASE_URL=file:./data/production.db

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# JWT & Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin User
ADMIN_EMAIL=bishoysamy390@gmail.com
ADMIN_PASSWORD=Bishoysamy2020

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.com

# Email Configuration (for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@mustashar.ai

# Wallet Configuration
CREDITS_PER_MESSAGE=10
CREDITS_PER_IMAGE=50
CREDITS_PER_FILE=100
